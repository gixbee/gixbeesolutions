# ─── Copy this to .env and fill in values ───────────────────────────────────
# Never commit .env — it is in .gitignore

# ── Database (used by postgres container + backend) ──────────────────────────
DATABASE_USER=postgres
DATABASE_PASSWORD=change_this_strong_password
DATABASE_NAME=gixbee
# DATABASE_HOST and DATABASE_PORT are injected by docker-compose — do not set here

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_this_redis_password
# REDIS_HOST and REDIS_PORT are injected by docker-compose — do not set here

# ── NestJS ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_very_long_random_string_at_least_64_chars
NODE_ENV=production
PORT=3000

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Firebase FCM (push notifications) ───────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ── Twilio (OTP SMS) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Or use Twilio Verify Service (recommended):
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxx

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ── Cloudinary (file uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
